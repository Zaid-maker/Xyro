# Required for uploading source maps during build
# Create token at: https://sentry.io/settings/auth-tokens/
# Required scopes: project:releases, org:read
SENTRY_AUTH_TOKEN=sntrys_your_token_here

# Optional if already provided through NEXT config/env in another file
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
