generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Recording {
  id              String   @id @default(cuid())
  cloudinaryId    String   @unique
  sharePath       String
  quality         String?
  secureUrl       String?
  durationSeconds Float?
  sizeBytes       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
