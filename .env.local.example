# Single source of truth for local development environment variables.

# Client-side DSN (safe to expose in browser)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Server/Edge DSN
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Optional, but recommended for release tagging
# SENTRY_RELEASE=your-app-version-or-git-sha

# Build-time metadata for source maps (optional here if set in next.config via env)
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# Cloudinary Configuration (for video storage)
# Sign up at https://cloudinary.com and get these from your dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# PostgreSQL database (Prisma)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
